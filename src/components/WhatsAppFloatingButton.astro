---
import { Icon } from "astro-icon/components";

const whatsappUrl = "https://wa.link/yvjra5";
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Open WhatsApp chat"
  class="fixed bottom-4 left-4 md:bottom-6 md:left-6 z-30 h-14 w-14 rounded-full bg-[#25D366] text-white shadow-lg shadow-dark/30 flex items-center justify-center transition-transform duration-200 hover:scale-105 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
>
  <Icon name="whatsapp" class="h-7 w-7 fill-white" />
</a>
